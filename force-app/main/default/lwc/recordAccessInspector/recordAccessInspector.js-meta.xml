<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata" fqn="recordAccessInspector">
  <apiVersion>65.0</apiVersion>
  <isExposed>true</isExposed>
  <masterLabel>Record Access Inspector</masterLabel>
  <description>Shows users who have read, write, or delete access to the current record and why.</description>
  <targets>
    <target>lightning__RecordPage</target>
  </targets>
  <targetConfigs>
    <targetConfig targets="lightning__RecordPage">
      <property
        name="compactLayout"
        type="Boolean"
        label="Compact layout"
        description="Renders the same access details in a dense admin-focused layout."
        default="false"
      />
      <property
        name="compactSize"
        type="String"
        label="Compact size"
        description="Choose the compact layout density."
        default="normal"
        datasource="normal,small"
      />
      <supportedFormFactors>
        <supportedFormFactor type="Large" />
        <supportedFormFactor type="Small" />
      </supportedFormFactors>
    </targetConfig>
  </targetConfigs>
</LightningComponentBundle>
